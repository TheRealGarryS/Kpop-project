  if (!html) throw new Error("KOCOWA seed fetch failed.");

  var articles = kocowa_extractArticles_(html);
  Logger.log("KOCOWA seed count = " + articles.length);

  articles.forEach(function(article) {
    if (article.url) {
      kocowa_markPosted_(article.url);
    }
  });

  Logger.log("KOCOWA seed complete.");
}
