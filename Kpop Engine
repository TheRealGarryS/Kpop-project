/**
 * Fetch page HTML
 */
function kocowa_fetchText_(url) {
  var options = {
    method: "get",
    muteHttpExceptions: true,
    followRedirects: true,
    headers: {
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36",
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "Accept-Language": "en-US,en;q=0.9",
      "Cache-Control": "no-cache",
      "Pragma": "no-cache"
    }
  };

  var res = UrlFetchApp.fetch(url, options);
  var code = res.getResponseCode();
  var text = res.getContentText();

  Logger.log("KOCOWA fetch " + url + " -> " + code);

  if (code < 200 || code >= 300) return "";
  return text;
}

/**
 * Extracts article cards from the KOCOWA K-Drama page.
 * Based on the page structure you pasted:
 * - article class contains category-k-drama
 * - title is in <h2 class="post-title-alt"><a ...>
 * - image is in <img ... data-src="...">
 */
function kocowa_extractArticles_(html) {
  var out = [];

  // grab each article block that is specifically category-k-drama
  var articleBlocks = html.match(/<article\b[\s\S]*?category-k-drama[\s\S]*?<\/article>/gi) || [];

  articleBlocks.forEach(function(block) {
    var title = "";
    var url = "";
    var imageUrl = "";

    // title + url from h2 post-title-alt
    var titleMatch = block.match(/<h2 class="post-title-alt">[\s\S]*?<a href="([^"]+)">([\s\S]*?)<\/a>/i);
    if (titleMatch) {
      url = kocowa_decodeHtml_(titleMatch[1] || "").trim();
      title = kocowa_stripTags_(kocowa_decodeHtml_(titleMatch[2] || "")).trim();
    }

    // fallback title/url if structure shifts a little
    if (!url || !title) {
      var fallbackMatch = block.match(/<a href="([^"]+)" class="image-link">[\s\S]*?<\/a>[\s\S]*?<h2 class="post-title-alt">[\s\S]*?<a href="([^"]+)">([\s\S]*?)<\/a>/i);
      if (fallbackMatch) {
        url = kocowa_decodeHtml_(fallbackMatch[2] || fallbackMatch[1] || "").trim();
        title = kocowa_stripTags_(kocowa_decodeHtml_(fallbackMatch[3] || "")).trim();
      }
    }

    // image from data-src first
    var imgMatch = block.match(/<img\b[^>]*data-src="([^"]+)"/i);
    if (imgMatch) {
      imageUrl = kocowa_decodeHtml_(imgMatch[1] || "").trim();
    }

    // fallback image from src if needed
    if (!imageUrl) {
      var imgMatch2 = block.match(/<img\b[^>]*src="([^"]+)"/i);
      if (imgMatch2) {
        imageUrl = kocowa_decodeHtml_(imgMatch2[1] || "").trim();
      }
    }

    if (url && title) {
      out.push({
        title: title,
        url: url,
        imageUrl: imageUrl
      });
    }
  });

  // dedupe within the page itself just in case
  var seen = {};
  return out.filter(function(item) {
    if (seen[item.url]) return false;
    seen[item.url] = true;
    return true;
  });
}

