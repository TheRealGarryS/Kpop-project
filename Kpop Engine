// ---------- CIRCLE TOP 200 ----------
function fetchCircleChartToSheet() {
  var sheet = getSheetOrThrow_(SHEET_CHART);

  // Preserve existing YouTube MVs before clearing
  var mvMap = {};
  var oldLast = sheet.getLastRow();
  if (oldLast >= 2) {
    var oldData = sheet.getRange(2, 1, oldLast - 1, 4).getValues();
    for (var i = 0; i < oldData.length; i++) {
      var songOld   = oldData[i][1];
      var artistOld = oldData[i][2];
      var mvOld     = oldData[i][3];
      if (songOld && artistOld && mvOld) {
        mvMap[makeKey_(artistOld, songOld)] = String(mvOld).trim();
      }
    }
  }

  sheet.clearContents();
  ensureChartHeader_(sheet);

  var latest = getLatestCircleWeek_();
  getSpreadsheet_().toast(
    "Detected Circle week " + latest.targetTime + " (" + latest.hitYear + ")"
  );

  var params = {
    nationGbn: "K",
    serviceGbn: "ALL",
    termGbn: "week",
    hitYear: latest.hitYear,
    targetTime: latest.targetTime,
    yearTime: "3"
  };

  var payload = "";
  for (var k in params) {
    if (payload) payload += "&";
    payload += encodeURIComponent(k) + "=" + encodeURIComponent(params[k]);
  }

  var options = {
    method: "post",
    payload: payload,
    muteHttpExceptions: true
  };

  var resp = UrlFetchApp.fetch(CIRCLE_API_URL, options);
  if (resp.getResponseCode() !== 200) {
    sheet.appendRow(["ERROR", "HTTP " + resp.getResponseCode(), "", "", "", "", ""]);
    throw new Error("Circle API returned HTTP " + resp.getResponseCode() + ": " + resp.getContentText());
  }

  var data = JSON.parse(resp.getContentText());
  var list = data && data.List ? data.List : null;
  if (!list) {
    sheet.appendRow(["ERROR", "No List in response", "", "", "", "", ""]);
    throw new Error("Circle API response did not include List.");
  }

  var rows = [];
  var keys = Object.keys(list);
  for (var j = 0; j < keys.length; j++) {
    var item = list[keys[j]];
    var rank = parseInt(item.RANK || item.SERVICE_RANK || item.SERVICE_RANKING || "9999", 10);
    if (isNaN(rank)) rank = 9999;

    var song = String(item.SONG_NAME || item.SONG || "").replace(/\s+/g, " ").trim();
    var artist = String(item.ARTIST_NAME || item.ARTIST || "").replace(/\s+/g, " ").trim();

    rows.push({ rank: rank, song: song, artist: artist });
  }

  rows.sort(function(a, b) { return a.rank - b.rank; });

  var n = Math.min(200, rows.length);
  if (n === 0) throw new Error("Circle returned zero rows.");

  var out = [];
  for (var r = 0; r < n; r++) {
    out.push([rows[r].rank, rows[r].song, rows[r].artist, "", "", "", ""]);
  }
  sheet.getRange(2, 1, out.length, 7).setValues(out);

  // Restore preserved MVs into column D
  var mvOut = [];
  for (var x = 0; x < out.length; x++) {
    var key2 = makeKey_(out[x][2], out[x][1]);
    mvOut.push([mvMap[key2] || ""]);
  }
  sheet.getRange(2, 4, mvOut.length, 1).setValues(mvOut);

  // EN translation formulas in E/F
  var eFormulas = [];
  var fFormulas = [];
  for (var rowNum = 2; rowNum < 2 + out.length; rowNum++) {
    eFormulas.push(['=IF(B' + rowNum + '="","",GOOGLETRANSLATE(B' + rowNum + ',"ko","en"))']);
    fFormulas.push(['=IF(C' + rowNum + '="","",GOOGLETRANSLATE(C' + rowNum + ',"ko","en"))']);
  }
  sheet.getRange(2, 5, out.length, 1).setFormulas(eFormulas);
  sheet.getRange(2, 6, out.length, 1).setFormulas(fFormulas);

  sheet.autoResizeColumns(1, 7);
  getSpreadsheet_().toast("Circle Top 200 loaded into " + SHEET_CHART + ".");
}


// ---------- YOUTUBE MV FETCH (TOP 50 BATCHED - USED BY AUTOMATION) ----------
function fetchYouTubeMVsBatch() {
  if (!YT_API_KEY) {
    getSpreadsheet_().toast("Paste your YouTube API key at the top of Code.gs (YT_API_KEY).");
    return;
  }

  var MAX_PER_RUN = 40;
  var TOP_N = 50;
  var TOP_LAST_ROW = 1 + TOP_N;
  var SLEEP_MS = 250;

  var sh = getSheetOrThrow_(SHEET_CHART);
  var lastRow = Math.min(sh.getLastRow(), TOP_LAST_ROW);
  if (lastRow < 2) return;

  var props = PropertiesService.getScriptProperties();
  var startRow = parseInt(props.getProperty(PROP_YT_NEXT_ROW) || "2", 10);
  if (isNaN(startRow) || startRow < 2) startRow = 2;
  if (startRow > lastRow) startRow = 2;

  var processed = 0;
  var row = startRow;

  while (row <= lastRow && processed < MAX_PER_RUN) {
    var title = sh.getRange(row, 2).getValue();
    var artist = sh.getRange(row, 3).getValue();
    var existing = sh.getRange(row, 4).getValue();

    if (!title || !artist) {
      sh.getRange(row, 7).setValue("missing title/artist");
      row++;
      continue;
    }

    if (existing) {
      row++;
      continue;
    }

    var r1 = ytSearch_(YT_API_KEY, artist + " " + title + " Official MV");
    var r2 = r1.videoId ? r1 : ytSearch_(YT_API_KEY, artist + " " + title + " MV");

    if (r2.ok && r2.videoId) {
      sh.getRange(row, 4).setValue("https://www.youtube.com/watch?v=" + r2.videoId);
      sh.getRange(row, 7).setValue("ok");
      processed++;
    } else if (!r2.ok) {
      sh.getRange(row, 7).setValue(r2.status);
      if (String(r2.status).indexOf("HTTP 403") !== -1) {
        props.setProperty(PROP_YT_NEXT_ROW, String(row));
        getSpreadsheet_().toast("YouTube quota hit (HTTP 403). Try after quota reset.");
        return;
      }
      processed++;
    } else {
      sh.getRange(row, 7).setValue("no results");
      processed++;
    }

    Utilities.sleep(SLEEP_MS);
    row++;
  }

  var nextRow = (row > lastRow) ? 2 : row;
  props.setProperty(PROP_YT_NEXT_ROW, String(nextRow));

  getSpreadsheet_().toast(
    "YouTube batch done (Top 50): " + processed + " processed. Next starts at row " + nextRow + "."
  );
}


