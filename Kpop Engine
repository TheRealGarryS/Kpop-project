/**************** KBS NEWS IMPORTER (RSS VERSION) ****************/

var KBS_TAB = "KBS_NEWS";
var KBS_RSS_URL = "http://world.kbs.co.kr/rss/rss_enternews.htm?lang=e";

function fetchKbsEnterNewsLinks() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ss.getSheetByName(KBS_TAB);
  if (!sh) throw new Error("Missing sheet: " + KBS_TAB);

  ensureKbsHeaders_(sh);

  var existingUrls = getExistingKbsUrls_(sh);

  var resp = UrlFetchApp.fetch(KBS_RSS_URL, {
    muteHttpExceptions: true,
    headers: { "User-Agent": "Mozilla/5.0" }
  });

  var code = resp.getResponseCode();
  var xmlText = resp.getContentText();

  if (code !== 200 || !xmlText) {
    throw new Error("KBS RSS fetch failed. HTTP " + code);
  }

  var doc = XmlService.parse(xmlText);
  var root = doc.getRootElement();
  var channel = root.getChild("channel");
  if (!channel) throw new Error("Invalid RSS: missing channel");

  var items = channel.getChildren("item");
  if (!items || !items.length) {
    SpreadsheetApp.getActiveSpreadsheet().toast("No RSS items found.");
    return;
  }

  var rowsToAppend = [];

  items.forEach(function(item) {
    var title = getChildText_(item, "title");
    var link = getChildText_(item, "link");
    var pubDate = getChildText_(item, "pubDate");
    var description = getChildText_(item, "description");

    if (!link || existingUrls[link]) return;

    rowsToAppend.push([
      link,                                        // A URL
      cleanHtmlText_(title || ""),                 // B Title
      pubDate || "",                               // C Date
      "",                                          // D Raw_Text
      trimToSentence_(cleanHtmlText_(description || "")), // E Summary
      "NEW",                                       // F Status
      ""                                           // G Blogger_URL
    ]);
  });

  if (!rowsToAppend.length) {
    SpreadsheetApp.getActiveSpreadsheet().toast("No new KBS RSS items found.");
    return;
  }

  sh.getRange(sh.getLastRow() + 1, 1, rowsToAppend.length, rowsToAppend[0].length)
    .setValues(rowsToAppend);

  SpreadsheetApp.getActiveSpreadsheet().toast("Added " + rowsToAppend.length + " new KBS RSS item(s).");
}

function ensureKbsHeaders_(sh) {
  var expected = [["URL", "Title", "Date", "Raw_Text", "Summary", "Status", "Blogger_URL"]];
  var current = sh.getRange(1, 1, 1, 7).getValues();

  var needsHeaders = false;
  for (var i = 0; i < 7; i++) {
    if (String(current[0][i]).trim() !== expected[0][i]) {
      needsHeaders = true;
      break;
    }
  }

  if (needsHeaders) {
    sh.getRange(1, 1, 1, 7).setValues(expected);
  }
}

function getExistingKbsUrls_(sh) {
  var lastRow = sh.getLastRow();
  var map = {};
  if (lastRow < 2) return map;

  var values = sh.getRange(2, 1, lastRow - 1, 1).getValues();
  values.forEach(function(r) {
    var url = String(r[0] || "").trim();
    if (url) map[url] = true;
  });
  return map;
}

function getChildText_(el, name) {
  var child = el.getChild(name);
  return child ? child.getText() : "";
}

function cleanHtmlText_(s) {
  if (!s) return "";

  return s
    .replace(/<[^>]+>/g, " ")
    .replace(/&nbsp;/gi, " ")
    .replace(/&amp;/gi, "&")
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/&rsquo;/gi, "'")
    .replace(/&lsquo;/gi, "'")
    .replace(/&ldquo;/gi, '"')
    .replace(/&rdquo;/gi, '"')
    .replace(/&hellip;/gi, "...")
    .replace(/<!\[CDATA\[|\]\]>/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function trimToSentence_(text) {
  if (!text) return "";
  var m = text.match(/^(.+?[.!?])\s/);
  return m ? m[1] : text;
}


