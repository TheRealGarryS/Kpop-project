function ytSearch_(apiKey, query) {
  var q = encodeURIComponent(query);
  var url =
    "https://www.googleapis.com/youtube/v3/search?part=snippet&type=video&maxResults=1&q=" +
    q + "&key=" + encodeURIComponent(apiKey);

  try {
    var res = UrlFetchApp.fetch(url, { muteHttpExceptions: true });
    var code = res.getResponseCode();
    if (code !== 200) return { ok: false, videoId: "", status: "HTTP " + code };

    var json = JSON.parse(res.getContentText());
    var item = (json.items && json.items.length > 0) ? json.items[0] : null;
    var videoId = (item && item.id && item.id.videoId) ? item.id.videoId : "";

    return { ok: true, videoId: videoId, status: videoId ? "ok" : "no results" };
  } catch (e) {
    return { ok: false, videoId: "", status: "error: " + (e.message || e.toString()) };
  }
}


// ---------- BUILD BLOG HTML ----------
function buildBlogHtmlFromTop10() {
  SpreadsheetApp.flush();

  var chart = getSheetOrThrow_(SHEET_CHART);
  var blog  = getSheetOrThrow_(SHEET_HTML);
  var latest = getLatestCircleWeek_();

  var lastRow = chart.getLastRow();
  if (lastRow < 11) throw new Error('Sheet "' + SHEET_CHART + '" does not have at least 10 chart rows.');

  var values = chart.getRange(2, 1, 10, 6).getDisplayValues();

  var weekNoDisplay = latest.weekNoDisplay;
  var dateRangeDisplay = formatCircleDateRangeForTitle_(latest.startDate, latest.endDate);

  var title = dateRangeDisplay
    ? "Circle Digital Top 10 - Week " + weekNoDisplay + " (" + dateRangeDisplay + ")"
    : "Circle Digital Top 10 - Week " + weekNoDisplay;

  var html = [];
  html.push('<div style="line-height:1.6;">');
  html.push("<p>Here is this week's Circle Digital Top 10 from Korea's digital chart.</p>");
  html.push('<ol>');

  for (var i = 0; i < values.length; i++) {
    var rank     = values[i][0];
    var songKr   = values[i][1];
    var artistKr = values[i][2];
    var mvUrl    = values[i][3];
    var songEn   = values[i][4];
    var artistEn = values[i][5];

    var songDisplay = songEn || songKr;
    var artistDisplay = artistEn || artistKr;

    html.push('<li>');
    html.push('<strong>#' + escapeHtml_(rank) + ' - ' + escapeHtml_(songDisplay) + '</strong><br>');
    html.push('Artist: ' + escapeHtml_(artistDisplay));

    if (songKr && songKr !== songDisplay) {
      html.push('<br><span style="color:#666;">KR: ' + escapeHtml_(songKr) + '</span>');
    }
    if (artistKr && artistKr !== artistDisplay) {
      html.push('<br><span style="color:#666;">Artist (KR): ' + escapeHtml_(artistKr) + '</span>');
    }
    if (mvUrl) {
      html.push('<br><a href="' + escapeHtml_(mvUrl) + '" target="_blank" rel="noopener">Watch MV</a>');
    }

    // Embed ONLY the #1 song video
    if (i === 0 && mvUrl) {
      var videoId = "";
      var match = String(mvUrl).match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^&?#]+)/i);
      if (match) videoId = match[1];

      if (videoId) {
        html.push('<br><div style="margin:12px 0 8px 0;">');
        html.push('<iframe width="100%" height="315" src="https://www.youtube.com/embed/' + escapeHtml_(videoId) + '" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>');
        html.push('</div>');
      }
    }

    html.push('</li>');
  }

  html.push('</ol>');
  html.push('<p><em>Source: Circle Chart Digital Weekly Chart.</em></p>');
  html.push('</div>');

  blog.getRange(CELL_BODY).setValue(html.join(""));
  blog.getRange(CELL_TITLE).setValue(title);

  getSpreadsheet_().toast("Built blog_HTML from Top 10 with #1 MV embedded.");
}


