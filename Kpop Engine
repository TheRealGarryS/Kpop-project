// ---------- BASIC HELPERS ----------
function getSpreadsheet_() {
  return SpreadsheetApp.getActiveSpreadsheet();
}

function getSheetOrThrow_(name) {
  var sh = getSpreadsheet_().getSheetByName(name);
  if (!sh) throw new Error('Sheet "' + name + '" not found.');
  return sh;
}

function escapeHtml_(s) {
  return String(s || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function formatDateForTitle_(yyyyMMddDot) {
  var parts = String(yyyyMMddDot || "").split(".");
  if (parts.length !== 3) return yyyyMMddDot;
  var d = new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
  return Utilities.formatDate(d, Session.getScriptTimeZone(), "MMMM d, yyyy");
}

function formatCircleDateRangeForTitle_(startDot, endDot) {
  if (!startDot || !endDot) return "";

  var startParts = String(startDot || "").split(".");
  var endParts   = String(endDot || "").split(".");

  if (startParts.length !== 3 || endParts.length !== 3) {
    return startDot + " - " + endDot;
  }

  var startDate = new Date(Number(startParts[0]), Number(startParts[1]) - 1, Number(startParts[2]));
  var endDate   = new Date(Number(endParts[0]), Number(endParts[1]) - 1, Number(endParts[2]));
  var tz = Session.getScriptTimeZone();

  var startMonth = Utilities.formatDate(startDate, tz, "MMMM");
  var endMonth   = Utilities.formatDate(endDate, tz, "MMMM");
  var startDay   = Utilities.formatDate(startDate, tz, "d");
  var endDay     = Utilities.formatDate(endDate, tz, "d");
  var endYear    = Utilities.formatDate(endDate, tz, "yyyy");

  if (startMonth === endMonth) {
    return startMonth + " " + startDay + "–" + endDay + ", " + endYear;
  }

  return startMonth + " " + startDay + "–" + endMonth + " " + endDay + ", " + endYear;
}

function normalizeWeekNumber_(weekNo) {
  return String(parseInt(String(weekNo || "").replace(/^0+/, ""), 10) || "");
}


// ---------- AUTO-DETECT LATEST CIRCLE WEEK ----------
function getLatestCircleWeek_() {
  var resp = UrlFetchApp.fetch(CIRCLE_PAGE_URL, {
    muteHttpExceptions: true,
    followRedirects: true,
    headers: { "User-Agent": "Mozilla/5.0 (compatible; GoogleAppsScript)" }
  });

  var code = resp.getResponseCode();
  var html = resp.getContentText();

  if (code !== 200) {
    throw new Error("Circle page returned HTTP " + code);
  }

  // NEW format seen on page: "2026 Weeks 13"
  var mNew = html.match(/(20\d{2})\s*Weeks?\s*(\d{1,2})/i);
  if (mNew) {
    var hitYearNew = mNew[1];
    var weekNoNew = normalizeWeekNumber_(mNew[2]);

    return {
      hitYear: hitYearNew,
      targetTime: weekNoNew,
      startDate: "",
      endDate: "",
      weekNoDisplay: weekNoNew,
      weekKey: hitYearNew + "-" + weekNoNew
    };
  }

  // OLD format: YYYY.MM.DD ~ YYYY.MM.DD (WW)
  var mOld = html.match(/(\d{4}\.\d{2}\.\d{2})\s*~\s*(\d{4}\.\d{2}\.\d{2})\s*\((\d{1,2})\)/);
  if (mOld) {
    var startDate = mOld[1];
    var endDate   = mOld[2];
    var weekNoOld = normalizeWeekNumber_(mOld[3]);
    var hitYearOld = startDate.substring(0, 4);

    return {
      hitYear: hitYearOld,
      targetTime: weekNoOld,
      startDate: startDate,
      endDate: endDate,
      weekNoDisplay: weekNoOld,
      weekKey: hitYearOld + "-" + weekNoOld
    };
  }

  throw new Error("Could not detect latest Circle week from page.");
}

function getCircleWeekKey_() {
  return getLatestCircleWeek_().weekKey;
}


// ---------- HELPER: Normalize key for matching songs week-to-week ----------
function makeKey_(artist, title) {
  function norm_(s) {
    s = String(s || "").toLowerCase().trim();
    s = s.replace(/\s+/g, " ");
    s = s.replace(/[’']/g, "'");
    s = s.replace(/[()【】\[\]]/g, " ");
    s = s.replace(/\s+/g, " ").trim();
    return s;
  }
  return norm_(artist) + "|" + norm_(title);
}


