/**************** KBS NEWS IMPORTER (RSS VERSION) ****************/
function fetchKbsEnterNewsLinks() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ss.getSheetByName(KBS_TAB);
  if (!sh) throw new Error("Missing sheet: " + KBS_TAB);

  ensureKbsHeaders_(sh);

  var existingUrls = getExistingKbsUrls_(sh);

  var resp = UrlFetchApp.fetch(KBS_RSS_URL, {
    muteHttpExceptions: true,
    headers: { "User-Agent": "Mozilla/5.0" }
  });

  var code = resp.getResponseCode();
  var xmlText = resp.getContentText();

  if (code !== 200 || !xmlText) {
    throw new Error("KBS RSS fetch failed. HTTP " + code);
  }

  var doc = XmlService.parse(xmlText);
  var root = doc.getRootElement();
  var channel = root.getChild("channel");
  if (!channel) throw new Error("Invalid RSS: missing channel");

  var items = channel.getChildren("item");
  if (!items || !items.length) {
    SpreadsheetApp.getActiveSpreadsheet().toast("No RSS items found.");
    return;
  }

  var rowsToAppend = [];

  items.forEach(function(item) {
    var title = getChildText_(item, "title");
    var link = getChildText_(item, "link");
    var pubDate = getChildText_(item, "pubDate");
    var description = getChildText_(item, "description");

    if (!link || existingUrls[link]) return;

    rowsToAppend.push([
      link,
      cleanHtmlText_(title || ""),
      pubDate || "",
      "",
      trimToSentence_(cleanHtmlText_(description || "")),
      "NEW",
      ""
    ]);
  });

  if (!rowsToAppend.length) {
    SpreadsheetApp.getActiveSpreadsheet().toast("No new KBS RSS items found.");
    return;
  }

  sh.getRange(sh.getLastRow() + 1, 1, rowsToAppend.length, rowsToAppend[0].length)
    .setValues(rowsToAppend);

  SpreadsheetApp.getActiveSpreadsheet().toast("Added " + rowsToAppend.length + " new KBS RSS item(s).");
}

function ensureKbsHeaders_(sh) {
  var expected = [["URL", "Title", "Date", "Raw_Text", "Summary", "Status", "Blogger_URL"]];
  var current = sh.getRange(1, 1, 1, 7).getValues();

  var needsHeaders = false;
  for (var i = 0; i < 7; i++) {
    if (String(current[0][i]).trim() !== expected[0][i]) {
      needsHeaders = true;
      break;
    }
  }

  if (needsHeaders) {
    sh.getRange(1, 1, 1, 7).setValues(expected);
  }
}

function getExistingKbsUrls_(sh) {
  var lastRow = sh.getLastRow();
  var map = {};
  if (lastRow < 2) return map;

  var values = sh.getRange(2, 1, lastRow - 1, 1).getValues();
  values.forEach(function(r) {
    var url = String(r[0] || "").trim();
    if (url) map[url] = true;
  });
  return map;
}

function getChildText_(el, name) {
  var child = el.getChild(name);
  return child ? child.getText() : "";
}

function cleanHtmlText_(s) {
  if (!s) return "";

  return s
    .replace(/<[^>]+>/g, " ")
    .replace(/&nbsp;/gi, " ")
    .replace(/&amp;/gi, "&")
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/&rsquo;/gi, "'")
    .replace(/&lsquo;/gi, "'")
    .replace(/&ldquo;/gi, '"')
    .replace(/&rdquo;/gi, '"')
    .replace(/&hellip;/gi, "...")
    .replace(/<!\[CDATA\[|\]\]>/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function trimToSentence_(text) {
  if (!text) return "";
  var m = text.match(/^(.+?[.!?])\s/);
  return m ? m[1] : text;
}


/*************** BUILD KBS POST (SAFE VERSION) ***************/
function buildKbsSignalsPost() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ss.getSheetByName(KBS_TAB);
  var htmlSheet = getKbsHtmlSheet_();

  if (!sh) throw new Error("Missing KBS_NEWS tab");

  var data = sh.getDataRange().getValues();
  if (data.length < 2) {
    SpreadsheetApp.getActiveSpreadsheet().toast("No data in KBS sheet");
    return;
  }

  var items = [];
  for (var i = 1; i < data.length; i++) {
    var row = data[i];
    var status = String(row[5] || "").trim();

    if (status === "NEW") {
      items.push({
        index: i + 1,
        title: row[1],
        summary: row[4],
        url: row[0]
      });
    }

    if (items.length >= 5) break;
  }

  if (!items.length) {
    SpreadsheetApp.getActiveSpreadsheet().toast("No NEW items found for KBS build");
    return;
  }

  var d = new Date();
  d.setDate(d.getDate() - 7);
  var weekNum = getWeekNumber_(d);

  var title = "Signals From Korean Broadcasting System - Week " + weekNum;
  var imageUrl = "https://i.imgur.com/qWnYR5o.png";

  var html = "";
  html += '<div style="line-height:1.6;">';
  html += '<p style="text-align:center;"><img src="' + imageUrl + '" width="420" /></p>';
  html += "<p>INCOMING TRANSMISSION:</p>";
  html += "<ul>";

  items.forEach(function(item) {
    html += "<li>" + escapeHtml_(item.summary || item.title) + "</li>";
  });

  html += "</ul>";
  html += "<p>End of signal.</p>";
  html += '<p><a href="https://world.kbs.co.kr/service/contents_list.htm?lang=e&menu_cate=enternews" target="_blank">Read more at KBS World Entertainment News</a></p>';
  html += "</div>";

  htmlSheet.getRange(KBS_CELL_BODY).setValue(html);
  htmlSheet.getRange(KBS_CELL_TITLE).setValue(title);
  htmlSheet.getRange(KBS_CELL_ROWS).setValue(
    items.map(function(item) { return item.index; }).join(",")
  );

  SpreadsheetApp.getActiveSpreadsheet().toast("KBS Signals post built into KBS_HTML.");
}


// ===== WEEK FUNCTION =====
function getWeekNumber_(date) {
  var d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  var dayNum = d.getUTCDay() || 7;
  d.setUTCDate(d.getUTCDate() + 4 - dayNum);
  var yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
  return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
}


/*************** PUBLISH KBS SIGNALS POST TO BLOGGER (SAFE VERSION) ***************/
function publishKbsSignalsPost_NOW() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var htmlSheet = ss.getSheetByName(KBS_HTML_TAB);
  var sh = ss.getSheetByName(KBS_TAB);

  if (!htmlSheet) throw new Error("Missing KBS_HTML tab");
  if (!sh) throw new Error("Missing KBS_NEWS tab");

  var content = String(htmlSheet.getRange(KBS_CELL_BODY).getValue() || "").trim();
  var title = String(htmlSheet.getRange(KBS_CELL_TITLE).getValue() || "").trim();

  if (!title) throw new Error("KBS_HTML!A2 is blank (missing KBS title)");
  if (!content) throw new Error("KBS_HTML!A1 is blank (missing KBS HTML content)");

  if (title.indexOf("Signals From Korean Broadcasting System") !== 0) {
    throw new Error("KBS publish aborted. Title does not look like a KBS post: " + title);
  }

  Logger.log("Attempting KBS publish...");
  Logger.log("Title: " + title);

  var url = "https://www.googleapis.com/blogger/v3/blogs/" + BLOG_ID_SIGNALS + "/posts/";

  var payload = {
    kind: "blogger#post",
    title: title,
    content: content
  };

  var resp = UrlFetchApp.fetch(url, {
    method: "post",
    contentType: "application/json",
    headers: {
      Authorization: "Bearer " + ScriptApp.getOAuthToken()
    },
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  var code = resp.getResponseCode();
  var text = resp.getContentText();

  Logger.log("Blogger code: " + code);
  Logger.log("Blogger response: " + text);

  if (code < 200 || code >= 300) {
    throw new Error("Blogger publish failed. HTTP " + code + " | " + text);
  }

  var json = JSON.parse(text);
  var postUrl = json.url || "";
  var postId = json.id || "";

  htmlSheet.getRange("A4").setValue("Published: " + new Date());
  htmlSheet.getRange("A5").setValue("Post URL: " + postUrl);
  htmlSheet.getRange("A6").setValue("Post ID: " + postId);

  var rowList = String(htmlSheet.getRange(KBS_CELL_ROWS).getValue() || "").trim();
  if (rowList) {
    rowList.split(",").forEach(function(n) {
      n = parseInt(String(n).trim(), 10);
      if (!isNaN(n) && n >= 2) {
        sh.getRange(n, 6).setValue("USED");
      }
    });
  }

  SpreadsheetApp.getActiveSpreadsheet().toast("KBS Signals post published!");
}

function hasNewKbsItems_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ss.getSheetByName(KBS_TAB);
  if (!sh) throw new Error("Missing KBS_NEWS tab");

  var lastRow = sh.getLastRow();
  if (lastRow < 2) return false;

  var statuses = sh.getRange(2, 6, lastRow - 1, 1).getValues();
  for (var i = 0; i < statuses.length; i++) {
    if (String(statuses[i][0] || "").trim() === "NEW") return true;
  }
  return false;
}

function getCurrentYearWeekKey_() {
  var d = new Date();
  var weekNum = getWeekNumber_(d);
  return Utilities.formatDate(d, Session.getScriptTimeZone(), "yyyy") + "-" + weekNum;
}

function weeklyKbsAutoRun() {
  var props = PropertiesService.getScriptProperties();
  var currentWeekKey = getCurrentYearWeekKey_();
  var lastPostedWeekKey = props.getProperty(PROP_LAST_KBS_POSTED_WEEK_KEY) || "";

  if (lastPostedWeekKey === currentWeekKey) {
    Logger.log("KBS skipped: already posted this week (" + currentWeekKey + ")");
    return;
  }

  fetchKbsEnterNewsLinks();
  SpreadsheetApp.flush();

  if (!hasNewKbsItems_()) {
    Logger.log("KBS skipped: no NEW items found.");
    return;
  }

  buildKbsSignalsPost();
  SpreadsheetApp.flush();

  publishKbsSignalsPost_NOW();
  SpreadsheetApp.flush();

  props.setProperty(PROP_LAST_KBS_POSTED_WEEK_KEY, currentWeekKey);
  Logger.log("KBS weekly automation complete for week " + currentWeekKey);
}

