function publishTop10ToBlogger_Core_(forcePublish) {
  var sheet = getSheetOrThrow_(SHEET_HTML);
  var latest = getLatestCircleWeek_();

  var title = String(sheet.getRange(CELL_TITLE).getDisplayValue() || "").trim();
  var html  = String(sheet.getRange(CELL_BODY).getDisplayValue() || "").trim();

  if (!title) throw new Error(SHEET_HTML + "!" + CELL_TITLE + " is blank (post title).");
  if (!html) throw new Error(SHEET_HTML + "!" + CELL_BODY + " is blank (post body).");

  var props = PropertiesService.getScriptProperties();
  var tz = Session.getScriptTimeZone();
  var todayKey = Utilities.formatDate(new Date(), tz, "yyyy-MM-dd");
  var currentWeekKey = latest.weekKey;

  sheet.getRange("A3").setValue("Attempting publish at " + new Date());
  sheet.getRange("A4").setValue("Title: " + title);
  sheet.getRange("A5").setValue("Force publish: " + forcePublish);
  sheet.getRange("A6").setValue("");

  if (!forcePublish) {
    var lastPostedWeekKey = props.getProperty(PROP_LAST_POSTED_WEEK_KEY) || "";
    if (lastPostedWeekKey === currentWeekKey) {
      var skippedUrl = props.getProperty(PROP_LAST_POST_URL) || "(blank)";
      sheet.getRange("A6").setValue("Skipped: week already posted (" + currentWeekKey + "). URL=" + skippedUrl);
      return skippedUrl;
    }
  }

  var endpoint = "https://www.googleapis.com/blogger/v3/blogs/" + BLOG_ID + "/posts/";
  var payload = {
    kind: "blogger#post",
    title: title,
    content: html
  };

  var token = ScriptApp.getOAuthToken();
  var resp = UrlFetchApp.fetch(endpoint, {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify(payload),
    headers: { Authorization: "Bearer " + token },
    muteHttpExceptions: true
  });

  var code = resp.getResponseCode();
  var body = resp.getContentText();

  sheet.getRange("A6").setValue("HTTP " + code + " | " + body.substring(0, 500));

  if (code < 200 || code >= 300) {
    throw new Error("Blogger API error " + code + ":\n" + body);
  }

  var data = JSON.parse(body);

  props.setProperty(PROP_LAST_PUB_DATE, todayKey);
  props.setProperty(PROP_LAST_POST_URL, data.url || "");
  props.setProperty(PROP_LAST_POST_ID, data.id || "");
  props.setProperty(PROP_LAST_POSTED_WEEK_KEY, currentWeekKey);

  sheet.getRange("A6").setValue(
    "SUCCESS | WEEK=" + currentWeekKey + " | URL=" + (data.url || "") + " | ID=" + (data.id || "")
  );

  return data.url || "";
}

