/************************************************************
 * KOCOWA K-DRAMA AUTO POSTER
 * ----------------------------------------------------------
 * Uses:
 * - existing BLOG_ID
 * - existing escapeHtml_()
 *
 * Posts:
 * - one post per KOCOWA K-Drama article
 * - Blogger title always: "Tuning In The KOCOWA Channel"
 * - body = title hyperlink + image below
 *
 * Dedupe:
 * - hidden Script Properties log by article URL
 ************************************************************/

var KOCOWA_KDRAMA_URL = "https://blog.kocowa.com/k-drama/";
var PROP_KOCOWA_POSTED_PREFIX = "KOCOWA_POSTED_";

/**
 * MAIN RUNNER
 * Use this for your daily trigger.
 */
function kocowa_runPoster() {
  var html = kocowa_fetchText_(KOCOWA_KDRAMA_URL);
  if (!html) {
    Logger.log("KOCOWA: could not fetch page.");
    return;
  }

  var articles = kocowa_extractArticles_(html);
  Logger.log("KOCOWA: articles found = " + articles.length);

  if (!articles.length) return;

  articles.forEach(function(article) {
    try {
      var url = String(article.url || "").trim();
      var title = String(article.title || "").trim();
      var imageUrl = String(article.imageUrl || "").trim();

      if (!url || !title) return;

      if (kocowa_alreadyPosted_(url)) {
        Logger.log("KOCOWA: already posted, skipping: " + url);
        return;
      }

      var postTitle = kocowa_buildBloggerTitle_();
      var postBody = kocowa_buildPostBody_(title, url, imageUrl);

      var result = kocowa_postToBlogger_(postTitle, postBody);
      Logger.log("KOCOWA: posted successfully: " + result);

      kocowa_markPosted_(url);

    } catch (err) {
      Logger.log("KOCOWA: error processing article: " + err);
    }
  });
}

/**
 * Blogger post title
 * EXACTLY as requested
 */
function kocowa_buildBloggerTitle_() {
  return "Tuning In The KOCOWA Channel";
}

/**
 * Blogger post body
 * EXACTLY as requested:
 * - article title as hyperlink
 * - image below
